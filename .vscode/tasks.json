{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Taskbar Monitor",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/python.exe",
            "args": [
                "${workspaceFolder}/src/main.py"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Install Dependencies (Fast - uv)",
            "type": "shell",
            "command": "uv",
            "args": [
                "pip",
                "install",
                "-e",
                ".[dev]"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build EXE: PyInstaller (Fast Dev)",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/python.exe",
            "args": [
                "-m",
                "PyInstaller",
                "--noconsole",
                "--onedir",
                "--clean",
                "--add-data=${workspaceFolder}/src/assets:assets",
                "--workpath=${workspaceFolder}/build",
                "--distpath=${workspaceFolder}/dist",
                "--specpath=${workspaceFolder}/build",
                "--paths=${workspaceFolder}/src",
                "--name=TaskbarMonitor_Dev",
                "src/main.py"
            ],
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Build EXE: PyInstaller (Production)",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/python.exe",
            "args": [
                "-m",
                "PyInstaller",
                "--noconsole",
                "--onefile",
                "--clean",
                "--add-data=${workspaceFolder}/src/assets:assets",
                "--exclude-module=PyQt6.QtWebEngine",
                "--exclude-module=PyQt6.QtSql",
                "--exclude-module=PyQt6.QtTest",
                "--exclude-module=PyQt6.QtXml",
                "--workpath=${workspaceFolder}/build",
                "--distpath=${workspaceFolder}/dist",
                "--specpath=${workspaceFolder}/build",
                "--paths=${workspaceFolder}/src",
                "--name=TaskbarMonitor",
                "src/main.py"
            ],
            "problemMatcher": [],
            "group": "build"
        }
    ]
}