{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Taskbar Monitor",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/python.exe",
            "args": [
                "${workspaceFolder}/src/main.py"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Install Dependencies",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/python.exe",
            "args": [
                "-m",
                "pip",
                "install",
                "-e",
                ".[dev]"
            ],
            "problemMatcher": []
        },
        {
            "label": "Lint: Ruff",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/python.exe",
            "args": [
                "-m",
                "ruff",
                "check",
                "src"
            ],
            "problemMatcher": []
        },
        {
            "label": "Type Check: Pyright",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/python.exe",
            "args": [
                "-m",
                "pyright",
                "src"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build EXE: PyInstaller",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/python.exe",
            "args": [
                "-m",
                "PyInstaller",
                "--noconsole",
                "--onefile",
                "--workpath=${workspaceFolder}/build",
                "--distpath=${workspaceFolder}/dist",
                "--specpath=${workspaceFolder}/build",
                "--paths=${workspaceFolder}/src",
                "--name=TaskbarMonitor",
                "src/main.py"
            ],
            "problemMatcher": [],
            "group": "build"
        }
    ]
}