{
    "workbench.editor.wrapTabs": true,
    "python.testing.unittestArgs": [
        "-v",
        "-s",
        "./tests",
        "-p",
        "*_test.py"
    ],
    "files.autoSave": "onWindowChange",
    "workbench.editor.tabSizing": "shrink",
    "python.testing.pytestEnabled": false,
    "python.testing.unittestEnabled": true,
    "[python]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "ms-python.black-formatter"
    },
    "editor.formatOnSave": true,
    "black-formatter.args": [
        "--line-length",
        "100",
        "--preview"
    ],
    "black-formatter.importStrategy": "fromEnvironment",
    "python.analysis.autoImportCompletions": false,
    "python.analysis.useLibraryCodeForTypes": true,
    "python.analysis.diagnosticMode": "workspace",
    "python.analysis.indexing": true,
    "workbench.editor.enablePreview": false,
    "python.linting.enabled": true,
    "python.linting.pylintEnabled": false,
    "python.linting.flake8Enabled": false,
    "python.linting.ruffEnabled": true,
    "python.formatting.provider": "yapf",
    "python.formatting.yapfArgs": [
        "--style",
        ".style.yapf"
    ],
    "python.linting.pylintArgs": [
        "--disable=not-an-iterable"
    ],
    "editor.rulers": [
        100
    ],
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "workbench.editor.labelFormat": "short",
    "cSpell.words": [
        "birthtime",
        "chromedriver",
        "cocenter",
        "dotenv",
        "Encryptor",
        "fprint",
        "getpid",
        "gids",
        "hpcc",
        "intelag",
        "iprompt",
        "levelname",
        "lngs",
        "Nuitka",
        "popleft",
        "prefs",
        "pyarmor",
        "PYTHONIOENCODING",
        "PYTHONUNBUFFERED",
        "setuptools",
        "topdown",
        "unindexed",
        "xpaths"
    ],
    "files.exclude": {
        "**/__pycache__": true
    },
    "python.analysis.autoSearchPaths": true,
    "python.analysis.extraPaths": [
        "${workspaceFolder}/intelag_packages/intelag_data_csv_serializer_pkg",
        "${workspaceFolder}/intelag_packages/intelag_task_manager_pkg",
        "${workspaceFolder}/intelag_packages/intelag_performance_indexer_pkg",
        "${workspaceFolder}/intelag_packages/intelag_config_model_pkg",
        "${workspaceFolder}/intelag_geo_tools_pkg",
        "${workspaceFolder}/intelag_packages/intelag_system_file_manager_pkg",
        "${workspaceFolder}/intelag_packages/intelag_encryptor_pkg",
        "${workspaceFolder}/intelag_packages/intelag_cache_manager_pkg",
        "${workspaceFolder}/intelag_packages/intelag_venv_manager_pkg",
        "${workspaceFolder}/intelag_packages/intelag_file_watcher_pkg",
        "${workspaceFolder}",
        "${workspaceFolder}/intelag_packages/intelag_shutdown_handler_pkg",
        "${workspaceFolder}/intelag_packages/intelag_logger_pkg",
        "${workspaceFolder}/intelag_packages/intelag_resource_manager_pkg",
        "${workspaceFolder}/intelag_runner_pkg",
    ],
    "cursorpyright.analysis.extraPaths": [
        "${workspaceFolder}/intelag_packages/intelag_data_csv_serializer_pkg",
        "${workspaceFolder}/intelag_packages/intelag_task_manager_pkg",
        "${workspaceFolder}/intelag_packages/intelag_performance_indexer_pkg",
        "${workspaceFolder}/intelag_packages/intelag_config_model_pkg",
        "${workspaceFolder}/intelag_geo_tools_pkg",
        "${workspaceFolder}/intelag_packages/intelag_system_file_manager_pkg",
        "${workspaceFolder}/intelag_packages/intelag_encryptor_pkg",
        "${workspaceFolder}/intelag_packages/intelag_cache_manager_pkg",
        "${workspaceFolder}/intelag_packages/intelag_venv_manager_pkg",
        "${workspaceFolder}/intelag_packages/intelag_file_watcher_pkg",
        "${workspaceFolder}",
        "${workspaceFolder}/intelag_packages/intelag_shutdown_handler_pkg",
        "${workspaceFolder}/intelag_packages/intelag_logger_pkg",
        "${workspaceFolder}/intelag_packages/intelag_resource_manager_pkg",
        "${workspaceFolder}/intelag_runner_pkg",
    ],
    "editor.tabFocusMode": false,
    "workbench.editor.highlightModifiedTabs": false,
    "workbench.editor.pinnedTabSizing": "normal",
    "workbench.editor.pinnedTabsOnSeparateRow": true,
    "workbench.editor.showTabs": "multiple",
    "explorer.copyPathSeparator": "/",
    "explorer.copyRelativePathSeparator": "/",
    "[yaml]": {
        "editor.defaultFormatter": "redhat.vscode-yaml",
        "yaml.format.sortKeys": false
    },
    "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
    "python.terminal.activateEnvironment": true,
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "python-envs.pythonProjects": [],
    "python-envs.defaultEnvManager": "ms-python.python:venv",
    "chat.tools.terminal.enableAutoApprove": true,
}